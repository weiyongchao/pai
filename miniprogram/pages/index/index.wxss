.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #eef0f3;
}

.page {
  min-height: 100vh;
}

.center-wrap {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.auth-btn {
  width: 360rpx;
}

.input {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  border: 2rpx solid #e6e8eb;
  border-radius: 14rpx;
  background: #fff;
  font-size: 28rpx;
}

.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 32rpx;
}

.modal {
  width: 640rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
}

.nick {
  font-size: 34rpx;
  font-weight: 600;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.history-item {
  padding: 16rpx 0;
  border-top: 2rpx solid #f0f1f2;
}

.history-item:first-child {
  border-top: none;
  padding-top: 0;
}

.history-right {
  gap: 14rpx;
  align-items: center;
}

.tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  background: #f6f7fb;
}

.tag.win {
  color: #07c160;
}

.tag.loss {
  color: #ff4d4f;
}

.tag.draw {
  color: #6b7785;
}

.num {
  font-size: 28rpx;
  font-weight: 700;
}

.score-pos {
  color: #07c160;
}

.score-neg {
  color: #ff4d4f;
}

.score-zero {
  color: #6b7785;
}
