.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #eef0f3;
}

.nick {
  font-size: 34rpx;
  font-weight: 700;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.item {
  padding: 18rpx 0;
  border-top: 2rpx solid #f0f1f2;
}

.item:first-child {
  border-top: none;
  padding-top: 0;
}

.win {
  color: #07c160;
  font-weight: 700;
}

.lose {
  color: #ff4d4f;
  font-weight: 700;
}

.danger-btn {
  background: #ff4d4f;
  color: #fff;
}

.round-scroll {
  margin-top: 14rpx;
  width: 100%;
}

.round-table {
  display: inline-block;
  border: 2rpx solid #f0f1f2;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

.round-row {
  display: flex;
  align-items: stretch;
}

.round-header {
  background: #f6f7fb;
}

.round-cell {
  width: 160rpx;
  min-width: 160rpx;
  max-width: 160rpx;
  padding: 14rpx 16rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  text-align: center;
  border-right: 2rpx solid #f0f1f2;
  border-bottom: 2rpx solid #f0f1f2;
  line-height: 1.3;
  word-break: break-all;
  white-space: normal;
  display: flex;
  align-items: center;
  justify-content: center;
}

.round-row:last-child .round-cell {
  border-bottom: none;
}

.round-cell:last-child {
  border-right: none;
}

.round-name {
  width: 200rpx;
  min-width: 200rpx;
  max-width: 200rpx;
  justify-content: flex-start;
  text-align: left;
  font-weight: 700;
}

.cell-pos {
  color: #07c160;
  font-weight: 700;
}

.cell-neg {
  color: #ff4d4f;
  font-weight: 700;
}

.cell-empty {
  color: #6b7785;
}

.cell-na {
  color: #9aa4b2;
}

.round-hint {
  margin-top: 14rpx;
  text-align: center;
}

.hint {
  margin-top: 14rpx;
  text-align: center;
}
