.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.content-scroll {
  flex: 1;
  min-height: 0;
}

.content {
  min-height: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-sizing: border-box;
  padding-bottom: 180rpx;
}

.logs-card {
  display: flex;
  flex-direction: column;
  max-height: 560rpx;
}

.logs-scroll {
  height: 440rpx;
  min-height: 300rpx;
  max-height: 440rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.section-head {
  margin-bottom: 16rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.seat-action {
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  font-size: 24rpx;
  font-weight: 800;
  border: 2rpx solid #e6e8eb;
  background: #ffffff;
  color: #1f2329;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.seat-actions {
  gap: 12rpx;
}

.seat-action-on {
  border-color: rgba(7, 193, 96, 0.28);
  color: #07c160;
  background: rgba(7, 193, 96, 0.08);
}

.table-area {
  position: relative;
  width: 100%;
  height: 630rpx;
  margin-top: 6rpx;
}

.table-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  border-radius: 999rpx;
  background: radial-gradient(circle at 50% 45%, rgba(7, 193, 96, 0.18) 0%, rgba(7, 193, 96, 0.06) 55%, rgba(0, 0, 0, 0.02) 100%);
  border: 2rpx solid rgba(7, 193, 96, 0.12);
}

.table-bg-rect {
  border-radius: 88rpx;
}

.table-bg-poly {
  border-radius: 0;
}

.table-ring {
  position: absolute;
  left: 28rpx;
  top: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  border-radius: 999rpx;
  border: 2rpx dashed rgba(7, 193, 96, 0.18);
}

.table-ring-rect {
  border-radius: 68rpx;
}

.table-ring-poly {
  border-radius: 0;
}

.table-center {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 196rpx;
  height: 196rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(7, 193, 96, 0.12);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.center-plus {
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 900;
  color: #07c160;
  background: rgba(7, 193, 96, 0.08);
}

.center-text {
  margin-top: 10rpx;
  font-weight: 800;
  font-size: 28rpx;
}

.center-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.2;
}

.seat {
  position: absolute;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 3;
}

.seat-edit .seat-avatar {
  border-color: rgba(22, 119, 255, 0.28);
}

.seat-selected {
  z-index: 4;
}

.seat-selected .seat-avatar {
  border-color: #1677ff;
  box-shadow: 0 0 0 6rpx rgba(22, 119, 255, 0.16), 0 10rpx 22rpx rgba(0, 0, 0, 0.12);
}

.seat-selected .seat-name {
  color: #1677ff;
}

.seat-lg {
  width: 148rpx;
}

.seat-md {
  width: 132rpx;
}

.seat-sm {
  width: 116rpx;
}

.seat-xs {
  width: 100rpx;
}

.seat-xxs {
  width: 84rpx;
}

.seat-avatar {
  display: block;
  margin: 0 auto;
  border-radius: 999rpx;
  background: #eef0f3;
  border: 4rpx solid rgba(255, 255, 255, 0.95);
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.12);
}

.seat-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  color: rgba(31, 35, 41, 0.58);
}

.seat-lg .seat-avatar-fallback {
  font-size: 36rpx;
}

.seat-md .seat-avatar-fallback {
  font-size: 32rpx;
}

.seat-sm .seat-avatar-fallback {
  font-size: 28rpx;
}

.seat-xs .seat-avatar-fallback {
  font-size: 24rpx;
}

.seat-xxs .seat-avatar-fallback {
  font-size: 20rpx;
}

.seat-lg .seat-avatar {
  width: 96rpx;
  height: 96rpx;
}

.seat-md .seat-avatar {
  width: 84rpx;
  height: 84rpx;
}

.seat-sm .seat-avatar {
  width: 72rpx;
  height: 72rpx;
}

.seat-xs .seat-avatar {
  width: 58rpx;
  height: 58rpx;
}

.seat-xxs .seat-avatar {
  width: 46rpx;
  height: 46rpx;
}

.seat-name {
  margin-top: 10rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.seat-lg .seat-name {
  font-size: 26rpx;
}

.seat-md .seat-name {
  font-size: 24rpx;
}

.seat-sm .seat-name {
  font-size: 22rpx;
}

.seat-xs .seat-name {
  margin-top: 6rpx;
  font-size: 18rpx;
}

.seat-xxs .seat-name {
  margin-top: 6rpx;
  font-size: 16rpx;
}

.seat-score {
  margin-top: 6rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
  font-weight: 900;
  font-variant-numeric: tabular-nums;
}

.seat-lg .seat-score {
  font-size: 24rpx;
}

.seat-md .seat-score {
  font-size: 22rpx;
}

.seat-sm .seat-score {
  font-size: 20rpx;
}

.seat-xs .seat-score {
  margin-top: 4rpx;
  font-size: 16rpx;
  padding: 4rpx 8rpx;
}

.seat-xxs .seat-score {
  margin-top: 4rpx;
  font-size: 14rpx;
  padding: 3rpx 6rpx;
}

.seat-score.score-pos {
  background: rgba(7, 193, 96, 0.12);
}

.seat-score.score-neg {
  background: rgba(255, 77, 79, 0.12);
}

.seat-score.score-zero {
  background: rgba(107, 119, 133, 0.12);
}

.seat-me-tag {
  position: absolute;
  top: 2rpx;
  right: 6rpx;
  background: rgba(0, 0, 0, 0.58);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.seat-hint {
  margin-top: 26rpx;
  font-size: 22rpx;
  line-height: 1.5;
  padding: 0 18rpx;
  text-align: center;
}

.score-pos {
  color: #07c160;
}

.score-neg {
  color: #ff4d4f;
}

.score-zero {
  color: #6b7785;
}

.tips-line {
  margin-top: 28rpx;
  font-size: 24rpx;
  line-height: 1.6;
  padding: 0 18rpx 4rpx;
  text-align: center;
}

.log {
  padding: 16rpx 0;
  border-top: 2rpx solid #f0f1f2;
  text-align: center;
}

.log:first-child {
  border-top: none;
  padding-top: 0;
}

.log-text {
  margin-top: 6rpx;
}

.log-name {
  color: #1677ff;
  font-weight: 700;
}

.log-amount {
  color: #ff7a45;
  font-weight: 700;
}

.mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal {
  width: 640rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.modal-room-code {
  min-height: 840rpx;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
}

.input {
  margin-top: 18rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  border: 2rpx solid #e6e8eb;
  border-radius: 14rpx;
  background: #fff;
  font-size: 28rpx;
}

.qrcode-box {
  width: 520rpx;
  height: 520rpx;
  margin: 18rpx auto 0;
  border-radius: 20rpx;
  background: #f7f8fa;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.qrcode {
  width: 520rpx;
  height: 520rpx;
  display: block;
}

.qrcode-tip {
  width: 100%;
  padding: 0 32rpx;
  box-sizing: border-box;
  text-align: center;
}

.mini {
  border-radius: 14rpx;
  padding: 12rpx 18rpx;
  font-size: 26rpx;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  width: auto;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  background: rgba(255, 255, 255, 0.98);
  border-top: 2rpx solid #f0f1f2;
  display: flex;
  gap: 16rpx;
  z-index: 50;
}

.footer-btn {
  flex: 1;
  border-radius: 18rpx;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  padding: 0 18rpx;
}

.danger-btn {
  background: #ff4d4f;
  color: #fff;
}

.profile-row {
  margin-top: 18rpx;
  gap: 20rpx;
  align-items: center;
}

.profile-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 999rpx;
  background: #eef0f3;
  flex: 0 0 auto;
}

.profile-fields {
  flex: 1;
  min-width: 0;
}

.label {
  font-size: 24rpx;
}
