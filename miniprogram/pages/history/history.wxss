.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #eef0f3;
}

.nick {
  font-size: 34rpx;
  font-weight: 600;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.timeline {
  position: relative;
  padding-left: 46rpx;
}

.timeline::before {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 14rpx;
  bottom: 14rpx;
  width: 2rpx;
  background: #e6e8eb;
}

.year-row {
  position: relative;
  padding: 10rpx 0 18rpx 0;
}

.year-dot {
  position: absolute;
  left: -28rpx;
  top: 24rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #d7dbe2;
  transform: translateX(-50%);
  box-shadow: 0 0 0 10rpx #ffffff;
}

.year-text {
  font-size: 36rpx;
  font-weight: 800;
  color: #6b7785;
  line-height: 1;
}

.record {
  position: relative;
  padding: 26rpx 0;
  border-top: 2rpx solid #f0f1f2;
}

.year-row + .record {
  border-top: none;
  padding-top: 10rpx;
}

.record-dot {
  position: absolute;
  left: -28rpx;
  top: 44rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #ff7a45;
  transform: translateX(-50%);
  box-shadow: 0 0 0 10rpx #ffffff;
}

.record-top {
  align-items: center;
}

.record-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2329;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 16rpx;
}

.record-right {
  gap: 14rpx;
  align-items: center;
  flex: 0 0 auto;
}

.chip {
  padding: 6rpx 12rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  color: #ffffff;
}

.chip.win {
  background: #ff7a45;
}

.chip.loss {
  background: #07c160;
}

.chip.draw {
  background: #6b7785;
}

.score {
  min-width: 96rpx;
  text-align: right;
  font-size: 34rpx;
  font-weight: 900;
  color: #1f2329;
}

.record-detail {
  margin-top: 14rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #6b7785;
  white-space: normal;
  word-break: break-all;
}

.record-detail.muted {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9aa4b2;
}
