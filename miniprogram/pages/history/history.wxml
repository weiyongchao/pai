<view class="container">
  <view wx:if="{{loading}}" class="loading-screen">
    <view class="loading-panel">
      <view class="spinner"></view>
      <view class="loading-text">加载中…</view>
    </view>
  </view>

  <view wx:else>
    <view class="card" wx:if="{{!me}}">
      <view class="muted">用户信息加载失败，请返回重试</view>
    </view>

    <view wx:else>
      <view class="card">
        <view class="row">
          <image class="avatar" src="{{me.avatarUrl}}" mode="aspectFill"></image>
          <view style="margin-left: 20rpx">
            <view class="nick">{{me.nickName}}</view>
            <view class="muted" style="margin-top: 8rpx">
              参与 {{me.stats.gamesPlayed}} · 胜 {{me.stats.wins}} · 负 {{me.stats.losses}}
            </view>
          </view>
        </view>
      </view>

      <view style="height: 24rpx"></view>

      <view class="card">
        <view class="section-title">历史战绩</view>
        <view wx:if="{{history.length === 0}}" class="muted" style="text-align:center">暂无记录</view>
        <view wx:else class="timeline">
          <block wx:for="{{history}}" wx:key="roomId">
            <view wx:if="{{item.showYearHeader}}" class="year-row">
              <view class="year-dot"></view>
              <view class="year-text">{{item.year}}</view>
            </view>

            <view class="record">
              <view class="record-dot"></view>
              <view class="record-body">
                <view class="row space-between record-top">
                  <view class="record-title">{{item.timeText}}  房:{{item.roomId}}</view>
                  <view class="row record-right">
                    <view class="chip {{item.resultClass}}">{{item.resultText}}</view>
                    <view class="score">{{item.absScoreText}}</view>
                  </view>
                </view>
                <view class="{{item.detailText ? 'record-detail' : 'record-detail muted'}}">
                  {{item.detailText || '该局暂无明细（旧数据）'}}
                </view>
              </view>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>
</view>
