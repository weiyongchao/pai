<view class="container">
  <view wx:if="{{loading}}" class="loading-screen">
    <view class="loading-panel">
      <view class="spinner"></view>
      <view class="loading-text">加载中…</view>
    </view>
  </view>

  <view wx:else>
    <view class="card" wx:if="{{!me}}">
      <view class="muted">请先在首页完成授权登录</view>
    </view>

    <view wx:else>
      <view class="card">
        <view class="row">
          <image class="avatar" src="{{me.avatarUrl}}" mode="aspectFill"></image>
          <view style="margin-left: 20rpx">
            <view class="nick">{{me.nickName}}</view>
            <view class="muted" style="margin-top: 8rpx">
              参与 {{me.stats.gamesPlayed}} · 胜 {{me.stats.wins}} · 负 {{me.stats.losses}}
            </view>
          </view>
        </view>
      </view>

      <view style="height: 24rpx"></view>

      <view class="card">
        <view class="section-title">历史战绩</view>
        <view wx:if="{{history.length === 0}}" class="muted" style="text-align:center">暂无记录</view>
        <view class="history-item row space-between" wx:for="{{history}}" wx:key="roomId">
          <view class="muted">{{item.time}}</view>
          <view class="row history-right">
            <view class="tag {{item.resultClass}}">{{item.resultText}}</view>
            <view class="num {{item.score > 0 ? 'score-pos' : (item.score < 0 ? 'score-neg' : 'score-zero')}}">{{item.scoreText}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
